<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <style>
        html {
            font-size: 14px;
        }
        body {
            font-family: Helvetica, sans-serif;
            height: 100%;
            font-size: 10px;
            padding: 86px 86px 0 86px;
            line-height: 1.33;
        }
        h1 { color: #333; }
        p { font-size: 1rem; }
        .app {
            display: flex;
            justify-content: space-between;
            flex-direction: column;
        }
        .paxum-icon {
            height: 40px;
            min-height: 40px;
            width: 223px;
        }

        .left-block {
            width: 60%;
        }
        .right-block {
            display: block;
            width: 43%;
            margin-left: 30px;
            color: #616C7B;
        }
        .b {
            font-weight: bold;
        }
        .grey-color {
            color: #616C7B;
        }
        .primary-color {
            color: #006cff
        }
        .text {
            width: 45%;
            min-width: 45%;
            text-transform: uppercase;
            font-size: 1rem;
            font-family: Helvetica;
            font-weight: normal;
            font-stretch: normal;
            font-style: normal;
            line-height: 1.2;
            letter-spacing: normal;
            color: #616c7b;
        }
        .info-line {
            display: flex;
            align-items: baseline;
            width: 100%;
            margin-top: 0.9rem;
            margin-bottom: 0.9rem;
        }
        .start {
            margin-bottom: 3rem;
        }
        .mt-3 {
            margin-top: 3rem;
        }
        .mb-1 {
            margin-bottom: 1rem;
        }
        .mb-2 {
            margin-bottom: 2rem;
        }
        .mb-3 {
            margin-bottom: 3rem;
        }
        .h1 {
            font-size: 2.3rem;
            font-weight: bold;
            line-height: 3.2rem;
            color: #000;
            margin-bottom: 2.1rem;
        }
        .text-value {
            font-size: 1rem;
            font-line: 1.2rem;
            font-family: Helvetica;
            font-weight: normal;
            font-stretch: normal;
            font-style: normal;
            line-height: normal;
            letter-spacing: normal;
            color: #000;
        }
        .text-line {
            display: block;
            height: 1px;
            background-color: #d1d9e3;
        }
        .footer-text {
            font-size: 1rem;
            line-height: 1.2rem;
            font-weight: normal;
            font-stretch: normal;
            font-style: normal;
            letter-spacing: normal;
            color: #000;
            margin-bottom: 1rem;
        }
        .footer-text-line {
            font-size: 0.8rem;
            line-height: 1.2rem;
            font-stretch: normal;
            font-style: normal;
            letter-spacing: normal;
            color: #000;
            margin-bottom: 1rem;
            font-weight: 800;
        }
        .footer-block {
            width: 100%;
            bottom: 4rem;
            margin-top: 2.5rem;
            position: absolute;
        }

        .footer {
            /*display: block;*/
            position: fixed;
            font-size: 0.8rem;
            line-height: 1.2rem;
            /*width: 100%;*/
            bottom: 86px;
        }
        .footer-line {
            border-top: 1px solid #d1d9e3;
            margin-bottom: 1.5rem;
            /*width: calc(100% - 101px);*/
            width: 605px
        }
        .beneficiary-name {
            font-size: 1rem;
            font-weight: bold;
            margin-bottom: 1.2rem;
        }
        .beneficiary-address {
            font-size: 1rem;
            line-height: 1.4;
            margin-bottom: 2.8rem;
        }
        .info-description {
            margin-bottom: 1.9rem;
            font-size: 1rem;
            line-height: 1.4rem;

        }
        .info-for {
            display: flex;
            flex-direction: column;
        }
        .text-replace {
            font-family: Helvetica;
            font-size: 1rem;
            font-weight: normal;
            font-stretch: normal;
            font-style: normal;
            line-height: 1.2;
            letter-spacing: normal;
            color: #616c7b;
            margin-top: 0.9rem;
        }
        .footer-flex {
            display: flex;
            justify-content: space-between;
        }
        .flex {
            display: flex;
        }
        .flex {
            display: flex;
        }
        .full-width-text {
            display: block;
            width: 100%;
            word-wrap: break-word;
            overflow-wrap: break-word;
            /*white-space: normal;*/
        }
        .text-value-danger {
            color: #f94141;
        }
        strong {
            font-weight: 400;
            color: #f94141;
        }
        .italic {
            margin-top: 10px;
            font-style: italic;
        }
    </style>
</head>
<body>
{% block content %}{% endblock %}
</body>
</html>
